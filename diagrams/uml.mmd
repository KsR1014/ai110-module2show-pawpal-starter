classDiagram
    %% PawPal+ initial design — four core classes.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int available_minutes
        +dict preferences
        +has_time_for(task) bool
        +allows(task) bool
    }

    class Pet {
        +str name
        +str species
        +str breed
        +list~Task~ tasks
        +add_task(task) void
        +summary() str
    }

    class Task {
        +str name
        +int duration_min
        +int priority
        +str category
        +time fixed_time
        +is_fixed() bool
        +label() str
    }

    class Scheduler {
        +dict constraints
        +build_plan(owner, tasks) list~Task~
        +explain_plan(owner, tasks) str
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler ..> Owner : reads constraints
    Scheduler ..> Task : schedules